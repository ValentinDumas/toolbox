{
  "name": "gestion-locative",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "db:migrate": "tsx src/infrastructure/db/database.ts migrate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bdd": "cucumber-js",
    "test:cov": "vitest run --coverage",
    "lint": "eslint --no-error-on-unmatched-pattern src tests",
    "lint:deps": "depcruise src",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/session": "^11.0.2",
    "@fastify/static": "^8.1.1",
    "@fastify/view": "^10.0.1",
    "@js-temporal/polyfill": "^0.5.0",
    "better-sqlite3": "^11.9.1",
    "ejs": "^3.1.10",
    "fastify": "^5.3.3",
    "fastify-type-provider-zod": "^4.0.2",
    "kysely": "^0.28.2",
    "pino": "^9.7.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@picocss/pico": "^2.1.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/coverage-v8": "^3.1.4",
    "dependency-cruiser": "^16.10.2",
    "eslint": "^9.26.0",
    "eslint-plugin-functional": "^7.3.0",
    "eslint-plugin-import": "^2.31.0",
    "fast-check": "^4.1.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
