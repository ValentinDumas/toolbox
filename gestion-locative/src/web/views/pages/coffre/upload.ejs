<%- include('../../partials/layout-debut', {
  titre: 'Ajouter un document',
  breadcrumbs: [
    { label: 'Coffre documentaire', url: '/coffre' },
    { label: 'Ajouter un document' }
  ],
  navActive: 'coffre'
}) %>

<h1>Ajouter un document</h1>

<% if (locals.erreurs && erreurs._global) { %>
  <aside role="alert" aria-live="assertive" style="color: var(--couleur-destructive, #b91c1c);">
    <%= erreurs._global %>
  </aside>
<% } %>

<form enctype="multipart/form-data" method="POST" action="/coffre/upload" novalidate>
  <%- include('../../partials/partial-upload-form', {
    biens: locals.biens || [],
    locataires: locals.locataires || [],
    erreurs: locals.erreurs || {},
    valeurs: locals.valeurs || {}
  }) %>
  <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
    <button type="submit">Téléverser le document</button>
    <a href="/coffre" role="button" class="secondary">Annuler</a>
  </div>
</form>

<style>
  .field-disabled { opacity: 0.5; pointer-events: none; }
</style>
<script>
  (function () {
    var $bien = document.getElementById('bienId');
    var $locataire = document.getElementById('locataireId');
    var $fieldBien = $bien ? $bien.closest('.field') : null;
    var $fieldLocataire = $locataire ? $locataire.closest('.field') : null;
    var radios = document.querySelectorAll('input[name="rattachement"]');

    function applyState(value) {
      var bienActif = value === 'bien' || value === 'bien_et_locataire';
      var locataireActif = value === 'locataire' || value === 'bien_et_locataire';
      if ($bien) {
        $bien.disabled = !bienActif;
        if ($fieldBien) $fieldBien.classList.toggle('field-disabled', !bienActif);
      }
      if ($locataire) {
        $locataire.disabled = !locataireActif;
        if ($fieldLocataire) $fieldLocataire.classList.toggle('field-disabled', !locataireActif);
      }
    }

    radios.forEach(function (radio) {
      radio.addEventListener('change', function (e) { applyState(e.target.value); });
    });

    var checked = Array.from(radios).find(function (r) { return r.checked; });
    applyState(checked ? checked.value : null);
  })();
</script>

<%- include('../../partials/layout-fin') %>
