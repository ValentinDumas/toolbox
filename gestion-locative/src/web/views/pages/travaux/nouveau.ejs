<%- include('../../partials/layout-debut', {
  titre: 'Nouveau ticket — ' + bien.adresse.enLigne(),
  breadcrumbs: [
    { url: '/biens', label: 'Biens' },
    { url: '/biens/' + bien.id, label: bien.adresse.enLigne() },
    { url: '/biens/' + bien.id + '/travaux', label: 'Travaux' },
    { label: 'Nouveau ticket' }
  ],
  navActive: 'biens'
}) %>

<h1>Nouveau ticket — <%= bien.adresse.enLigne() %></h1>

<% if (locals.erreurs && erreurs._global) { %>
  <aside role="alert" aria-live="assertive" style="color: var(--couleur-destructive, #b91c1c);">
    <%= erreurs._global %>
  </aside>
<% } %>

<form method="POST" action="/biens/<%= bien.id %>/travaux" novalidate>
  <div class="field">
    <label for="titre">Titre <span aria-hidden="true">*</span></label>
    <input
      id="titre"
      name="titre"
      type="text"
      required
      maxlength="200"
      value="<%= (locals.valeurs && locals.valeurs.titre) || '' %>"
      <% if (locals.erreurs && erreurs.titre) { %>aria-invalid="true" aria-describedby="titre-error"<% } %>
    />
    <% if (locals.erreurs && erreurs.titre) { %>
      <span id="titre-error" role="alert" style="color: var(--couleur-destructive, #b91c1c);"><%= erreurs.titre %></span>
    <% } %>
  </div>

  <div class="field">
    <label for="description">Description <span aria-hidden="true">*</span></label>
    <textarea
      id="description"
      name="description"
      required
      maxlength="5000"
      rows="4"
      <% if (locals.erreurs && erreurs.description) { %>aria-invalid="true" aria-describedby="description-error"<% } %>
    ><%= (locals.valeurs && locals.valeurs.description) || '' %></textarea>
    <% if (locals.erreurs && erreurs.description) { %>
      <span id="description-error" role="alert" style="color: var(--couleur-destructive, #b91c1c);"><%= erreurs.description %></span>
    <% } %>
  </div>

  <div class="field">
    <label for="dateOuverture">Date d'ouverture <span aria-hidden="true">*</span></label>
    <input
      id="dateOuverture"
      name="dateOuverture"
      type="date"
      required
      max="<%= locals.today ? locals.today.toString() : '' %>"
      value="<%= (locals.valeurs && locals.valeurs.dateOuverture) || (locals.today ? locals.today.toString() : '') %>"
      <% if (locals.erreurs && erreurs.dateOuverture) { %>aria-invalid="true" aria-describedby="dateOuverture-error"<% } %>
    />
    <% if (locals.erreurs && erreurs.dateOuverture) { %>
      <span id="dateOuverture-error" role="alert" style="color: var(--couleur-destructive, #b91c1c);"><%= erreurs.dateOuverture %></span>
    <% } %>
  </div>

  <div class="field">
    <label for="coutEstimeTtcEuros">Coût estimé TTC (€) <small>(optionnel)</small></label>
    <input
      id="coutEstimeTtcEuros"
      name="coutEstimeTtcEuros"
      type="number"
      step="0.01"
      min="0"
      value="<%= (locals.valeurs && locals.valeurs.coutEstimeTtcEuros) || '' %>"
    />
  </div>

  <div class="field">
    <label for="notes">Notes <small>(optionnel)</small></label>
    <textarea id="notes" name="notes" maxlength="2000" rows="3"><%= (locals.valeurs && locals.valeurs.notes) || '' %></textarea>
  </div>

  <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
    <button type="submit" style="min-height: 44px;">Créer le ticket</button>
    <a href="/biens/<%= bien.id %>/travaux" role="button" class="secondary" style="min-height: 44px;">Annuler</a>
  </div>
</form>

<%- include('../../partials/layout-fin') %>
