<%- include('../../partials/layout-debut', {
  titre: bien.adresse.enLigne(),
  breadcrumbs: [{ url: '/biens', label: 'Biens' }, { label: bien.adresse.enLigne() }],
  navActive: 'biens'
}) %>

<h1><%= bien.adresse.enLigne() %></h1>

<dl>
  <dt>Type</dt><dd><%= bien.type %></dd>
  <dt>Surface</dt><dd><%= bien.surface %> m²</dd>
  <dt>Année de construction</dt><dd><%= bien.anneeConstruction %></dd>
</dl>

<p>
  <a href="/biens/<%= bien.id %>/modifier" role="button">Modifier le bien</a>
  &nbsp;
  <button type="button" data-open-dialog="dialog-supprimer-bien">Supprimer le bien</button>
</p>

<%- include('../../partials/confirm-dialog', {
  id: 'dialog-supprimer-bien',
  formAction: '/biens/' + bien.id + '/supprimer',
  message: 'Supprimer ' + bien.adresse.enLigne() + ' ? Cette action est irréversible. Les lots associés seront également supprimés.',
  confirmLabel: 'Supprimer définitivement',
  cancelLabel: 'Annuler'
}) %>

<h2>Actions sur ce bien</h2>
<p>
  <a href="/locataires/nouveau?bienId=<%= bien.id %>" role="button" class="secondary">Ajouter un locataire pour ce bien</a>
  &nbsp;
  <a href="/baux/nouveau?bienId=<%= bien.id %>" role="button" class="secondary">Créer un bail sur ce bien</a>
</p>
<p><small>Astuce : commencez par créer un locataire, puis liez-le à ce bien via un bail.</small></p>

<h2>Lots</h2>

<% if (bien.lots.length === 0) { %>
  <p>Aucun lot sur ce bien</p>
  <p>Tout bien doit avoir au moins un lot. Ajoutez un appartement, un parking ou une cave.</p>
  <p><a href="/biens/<%= bien.id %>/lots">Ajouter un lot</a></p>
<% } else { %>
  <%- include('../../partials/data-table', {
    ariaLabel: 'Lots du bien',
    colonnes: [
      { titre: 'Désignation' },
      { titre: 'Type' },
      { titre: 'Surface', numerique: true },
      { titre: 'Étage', numerique: true },
      { titre: 'Actions', srOnly: true }
    ],
    lignes: bien.lots.map(function(l) {
      return [
        l.designation,
        l.type,
        l.surface !== null ? l.surface + ' m²' : '—',
        l.etage !== null ? String(l.etage) : '—'
      ];
    }),
    actions: function(ligne, i) {
      const lot = bien.lots[i];
      return '<button type="button" class="destructif" data-open-dialog="dialog-supprimer-lot-' + lot.id + '">Supprimer</button>';
    }
  }) %>

  <% bien.lots.forEach(function(lot) { %>
    <%- include('../../partials/confirm-dialog', {
      id: 'dialog-supprimer-lot-' + lot.id,
      formAction: '/biens/' + bien.id + '/lots/' + lot.id + '/supprimer',
      message: 'Supprimer le lot ' + lot.designation + ' ? Cette action est irréversible.',
      confirmLabel: 'Supprimer définitivement',
      cancelLabel: 'Annuler'
    }) %>
  <% }); %>
<% } %>

<h2>Ajouter un lot</h2>
<form method="POST" action="/biens/<%= bien.id %>/lots" novalidate>
  <%- include('../../partials/form-field', {
    id: 'ajout-lot-designation',
    name: 'designation',
    label: 'Désignation',
    value: '',
    erreur: locals.erreurAjoutLot || null
  }) %>
  <div class="field">
    <label for="ajout-lot-type">Type de lot <span aria-hidden="true">*</span></label>
    <select id="ajout-lot-type" name="type" required>
      <option value="appartement">Appartement</option>
      <option value="parking">Parking</option>
      <option value="cave">Cave</option>
      <option value="local_commercial">Local commercial</option>
      <option value="terrasse">Terrasse</option>
      <option value="autre">Autre</option>
    </select>
  </div>
  <%- include('../../partials/form-field', {
    id: 'ajout-lot-surface',
    name: 'surface',
    label: 'Surface (m²)',
    type: 'number',
    value: '',
    required: false,
    hint: 'Obligatoire pour appartement ou local commercial'
  }) %>
  <%- include('../../partials/form-field', {
    id: 'ajout-lot-etage',
    name: 'etage',
    label: 'Étage',
    type: 'number',
    value: '',
    required: false
  }) %>
  <button type="submit">Ajouter un lot</button>
</form>


<section aria-labelledby="diagnostics-heading">
  <h2 id="diagnostics-heading">Diagnostics <%- include('../../partials/partial-badge-dpe', { classe: bien.classeDpe }) %></h2>

  <%
    const diagnosticsExpires = bien.diagnostics.filter(function(d) { return d.estExpire(today); });
  %>
  <% if (diagnosticsExpires.length > 0) { %>
    <aside class="banniere-warning" aria-live="polite" style="background: #fef3c7; border-left: 4px solid #d97706; padding: 12px 16px; margin-bottom: 16px;">
      &#9888; Le diagnostic <%= formaterTypeDiagnostic(diagnosticsExpires[0].type) %> a expiré
      <% if (diagnosticsExpires[0].dateExpiration) { %>le <%= formatDate(diagnosticsExpires[0].dateExpiration) %><% } %>.
      Pensez à le renouveler avant la prochaine relocation.
    </aside>
  <% } %>

  <% if (bien.diagnostics.length === 0) { %>
    <%- include('../../partials/empty-state', {
      heading: 'Aucun diagnostic enregistré',
      body: 'Les diagnostics obligatoires (DPE, gaz, électricité, ERP) doivent être annexés au bail.',
      ctaUrl: '/biens/' + bien.id + '/diagnostics/nouveau',
      ctaLabel: 'Ajouter un diagnostic'
    }) %>
  <% } else if (bien.classeDpe === null || bien.classeDpe === undefined) { %>
    <%- include('../../partials/empty-state', {
      heading: 'Classe DPE non renseignée',
      body: 'Aucun diagnostic DPE valide n\'est associé à ce bien. La classe DPE est nécessaire pour vérifier le gel loyer Climat (DPE F/G) avant indexation IRL.',
      ctaUrl: '/biens/' + bien.id + '/diagnostics/nouveau',
      ctaLabel: 'Ajouter un DPE'
    }) %>
    <table role="table" aria-label="Diagnostics du bien">
      <caption class="sr-only">Diagnostics du bien</caption>
      <thead>
        <tr>
          <th scope="col">Type</th>
          <th scope="col">Date d'émission</th>
          <th scope="col">Date d'expiration</th>
          <th scope="col">Statut</th>
        </tr>
      </thead>
      <tbody>
        <% bien.diagnostics.forEach(function(d) { %>
          <%- include('../../partials/partial-diagnostic-row', {
            d: d,
            today: today,
            helpers: { formaterTypeDiagnostic: formaterTypeDiagnostic, formatDate: formatDate, formaterStatutDiagnostic: formaterStatutDiagnostic }
          }) %>
        <% }) %>
      </tbody>
    </table>
    <p>
      <a href="/biens/<%= bien.id %>/diagnostics/nouveau" role="button">Ajouter un diagnostic</a>
    </p>
  <% } else { %>
    <table role="table" aria-label="Diagnostics du bien">
      <caption class="sr-only">Diagnostics du bien</caption>
      <thead>
        <tr>
          <th scope="col">Type</th>
          <th scope="col">Date d'émission</th>
          <th scope="col">Date d'expiration</th>
          <th scope="col">Statut</th>
        </tr>
      </thead>
      <tbody>
        <% bien.diagnostics.forEach(function(d) { %>
          <%- include('../../partials/partial-diagnostic-row', {
            d: d,
            today: today,
            helpers: { formaterTypeDiagnostic: formaterTypeDiagnostic, formatDate: formatDate, formaterStatutDiagnostic: formaterStatutDiagnostic }
          }) %>
        <% }) %>
      </tbody>
    </table>
    <p>
      <a href="/biens/<%= bien.id %>/diagnostics/nouveau" role="button">Ajouter un diagnostic</a>
    </p>
  <% } %>
</section>

<%- include('../../partials/layout-fin') %>
