<%- include('../../partials/layout-debut', { titre: 'Biens', banniereSuccess: locals.banniereSuccess ?? null }) %>

<nav aria-label="Fil d'Ariane">
  <ul>
    <li><a href="/">Accueil</a></li>
    <li>Biens</li>
  </ul>
</nav>

<h1>Biens</h1>

<p><a href="/biens/nouveau" role="button">Créer un bien</a></p>

<% if (biens.length === 0) { %>
  <p>Aucun bien pour l'instant</p>
  <p>Ajoutez votre premier bien immobilier pour démarrer la gestion locative.</p>
<% } else { %>
  <%- include('../../partials/data-table', {
    ariaLabel: 'Liste des biens',
    colonnes: [
      { titre: 'Adresse' },
      { titre: 'Type' },
      { titre: 'Surface', numerique: true },
      { titre: 'Année', numerique: true },
      { titre: 'Lots', numerique: true },
      { titre: 'Actions', srOnly: true }
    ],
    lignes: biens.map(function(b) {
      return [
        b.adresse.enLigne(),
        b.type,
        b.surface + ' m²',
        String(b.anneeConstruction),
        String(b.lots.length)
      ];
    }),
    actions: function(ligne, i) {
      const b = biens[i];
      return '<a href="/biens/' + b.id + '">Voir</a> '
        + '<a href="/biens/' + b.id + '/modifier">Modifier</a> '
        + '<button type="button" class="destructif" data-open-dialog="dialog-supprimer-' + b.id + '">Supprimer</button>';
    }
  }) %>

  <% biens.forEach(function(b) { %>
    <%- include('../../partials/confirm-dialog', {
      id: 'dialog-supprimer-' + b.id,
      formAction: '/biens/' + b.id + '/supprimer',
      message: 'Supprimer ' + b.adresse.enLigne() + ' ? Cette action est irréversible. Les lots associés seront également supprimés.',
      confirmLabel: 'Supprimer définitivement',
      cancelLabel: 'Annuler'
    }) %>
  <% }); %>
<% } %>

<%- include('../../partials/layout-fin') %>
