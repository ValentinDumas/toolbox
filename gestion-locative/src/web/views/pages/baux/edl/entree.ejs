<%- include('../../../partials/layout-debut', {
  titre: "EDL d'entrée — " + locals.bail.id,
  breadcrumbs: [
    { url: '/baux', label: 'Baux' },
    { url: '/baux/' + locals.bail.id, label: 'Bail' },
    { label: "État des lieux d'entrée" }
  ],
  navActive: 'baux'
}) %>

<h1>État des lieux d'entrée</h1>

<%- include('../../../partials/banniere-warning', { message: locals.banniereWarning }) %>

<% if (!locals.edl) { %>
  <p>Aucun EDL d'entrée actif pour ce bail.</p>
  <p><a href="/baux/<%= locals.bail.id %>/edl/entree/nouveau" role="button">Enregistrer un EDL d'entrée</a></p>
<% } else { %>
  <dl>
    <dt>Date de l'EDL</dt><dd><%= formatDate(locals.edl.dateEdl) %></dd>
    <dt>Contradictoire</dt><dd><%= locals.edl.contradictoire ? 'Oui' : 'Non' %></dd>
    <% if (locals.edl.dateSignature) { %>
      <dt>Date de signature</dt><dd><%= formatDate(locals.edl.dateSignature) %></dd>
    <% } %>
    <% if (locals.edl.annuleLe) { %>
      <dt>Annulé le</dt><dd><%= formatDate(locals.edl.annuleLe) %></dd>
      <dt>Raison</dt><dd><%= locals.edl.raisonAnnulation %></dd>
    <% } %>
  </dl>

  <%- include('../../../partials/partial-inventaire-display', {
    inventaire: locals.edl.inventaire,
    formaterTypeItemInventaire: locals.formaterTypeItemInventaire,
    formaterEtatItem: locals.formaterEtatItem,
  }) %>

  <% if (!locals.edl.annuleLe) { %>
    <form method="POST" action="/baux/<%= locals.bail.id %>/edl/entree/<%= locals.edl.id %>/annuler">
      <div class="field">
        <label for="raison">Raison d'annulation <span aria-hidden="true">*</span></label>
        <input type="text" id="raison" name="raison" required maxlength="500">
      </div>
      <button type="submit" class="destructif">Annuler cet EDL</button>
    </form>
  <% } %>
<% } %>

<p><a href="/baux/<%= locals.bail.id %>">Retour à la fiche bail</a></p>

<%- include('../../../partials/layout-fin') %>
