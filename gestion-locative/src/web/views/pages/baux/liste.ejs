<%- include('../../partials/layout-debut', {
  titre: 'Baux',
  breadcrumbs: [{ label: 'Baux' }],
  navActive: 'baux'
}) %>

<% if (biensCount === 0 || locatairesCount === 0) { %>
  <%- include('../../partials/empty-state', {
    heading: "Impossible de créer un bail",
    body: "Vous avez besoin d'au moins 1 bien et 1 locataire avant de créer un bail.",
    ctaLabel: biensCount === 0 ? "Créer un bien" : "Créer un locataire",
    ctaUrl: biensCount === 0 ? "/biens/nouveau" : "/locataires/nouveau"
  }) %>
<% } else if (baux.length === 0) { %>
  <%- include('../../partials/empty-state', {
    heading: "Aucun bail pour l'instant",
    body: "Reliez un bien à un locataire en créant votre premier bail meublé.",
    ctaLabel: "Créer un bail",
    ctaUrl: "/baux/nouveau"
  }) %>
<% } else { %>
  <h1>Baux</h1>
  <p><a href="/baux/nouveau" role="button">Créer un bail</a></p>

  <%- include('../../partials/data-table', {
    ariaLabel: 'Liste des baux',
    colonnes: [
      { titre: 'Locataire' },
      { titre: 'Adresse du bien' },
      { titre: 'Loyer HC', numerique: true },
      { titre: 'Date début' },
      { titre: 'Durée' },
      { titre: 'Actions', srOnly: true }
    ],
    lignes: baux.map(function(b) {
      return [
        biensMap[b.bienId] ? locatairesMap[b.locataireId] || b.locataireId : b.locataireId,
        biensMap[b.bienId] ? biensMap[b.bienId].adresse.enLigne() : b.bienId,
        locals.formatMoney ? locals.formatMoney(b.loyerHc) : b.loyerHc.enEuros(),
        locals.formatDate ? locals.formatDate(b.dateDebut) : formatDate(b.dateDebut),
        b.dureeMois + ' mois'
      ];
    }),
    actions: function(ligne, i) {
      const b = baux[i];
      return '<a href="/baux/' + b.id + '">Voir</a> '
        + '<a href="/baux/' + b.id + '/modifier">Modifier</a> '
        + '<button type="button" class="destructif" data-open-dialog="dialog-supprimer-' + b.id + '">Supprimer</button>';
    }
  }) %>

  <% baux.forEach(function(b) { %>
    <%- include('../../partials/confirm-dialog', {
      id: 'dialog-supprimer-' + b.id,
      formAction: '/baux/' + b.id + '/supprimer',
      message: 'Supprimer ce bail ? Cette action est irréversible.',
      confirmLabel: 'Supprimer définitivement',
      cancelLabel: 'Annuler'
    }) %>
  <% }); %>
<% } %>

<%- include('../../partials/layout-fin') %>
