<%- include('../../partials/layout-debut', {
  titre: 'Bail — ' + locataire.prenom + ' ' + locataire.nom,
  breadcrumbs: [{ url: '/baux', label: 'Baux' }, { label: 'Bail de ' + locataire.prenom + ' ' + locataire.nom }],
  navActive: 'baux'
}) %>

<h1>Bail de <%= locataire.prenom %> <%= locataire.nom %> au <%= bien.adresse.enLigne() %></h1>

<%- include('../../partials/banniere-warning', { message: locals.banniereWarning }) %>

<% if (locals.bailIndexable && locals.dateAnniversaire) { %>
  <%- include('../../partials/partial-indexation-banner', {
    bailId: bail.id,
    dateAnniversaire: locals.dateAnniversaire
  }) %>
<% } %>

<h2>Locataire</h2>
<dl>
  <dt>Nom</dt><dd><%= locataire.nom %></dd>
  <dt>Prénom</dt><dd><%= locataire.prenom %></dd>
  <dt>Email</dt><dd><a href="mailto:<%= locataire.email %>"><%= locataire.email %></a></dd>
  <dt>Téléphone</dt><dd><%= locataire.telephone || '—' %></dd>
</dl>
<p><a href="/locataires/<%= locataire.id %>">Voir la fiche locataire</a></p>

<h2>Bien</h2>
<dl>
  <dt>Adresse</dt><dd><%= bien.adresse.enLigne() %></dd>
  <dt>Type</dt><dd><%= bien.type %></dd>
</dl>
<h3>Lots concernés par ce bail</h3>
<ul>
  <% lotsduBail.forEach(function(lot) { %>
    <li><%= lot.designation %><% if (lot.surface) { %> — <%= lot.surface %> m²<% } %></li>
  <% }); %>
</ul>
<p><a href="/biens/<%= bien.id %>">Voir la fiche bien</a></p>

<h2>Conditions financières</h2>
<dl>
  <dt>Loyer hors charges</dt><dd><%= formatMoney(bail.loyerHc) %></dd>
  <dt>Mode de charges</dt><dd><%= bail.modeCharges === 'forfait' ? 'Forfait mensuel' : 'Provisions sur charges' %></dd>
  <dt>Montant des charges</dt><dd><%= formatMoney(bail.montantCharges) %></dd>
  <dt>Dépôt de garantie</dt><dd><%= formatMoney(bail.depotGarantie) %></dd>
</dl>

<h2>Période</h2>
<dl>
  <dt>Date de début</dt><dd><%= formatDate(bail.dateDebut) %></dd>
  <dt>Durée</dt><dd><%= bail.dureeMois %> mois</dd>
  <% if (bail.actifDepuis !== null) { %>
    <dt>Actif depuis</dt>
    <dd><%= formatDate(bail.actifDepuis) %></dd>
  <% } %>
</dl>

<h2>IRL de référence</h2>
<dl>
  <dt>Trimestre</dt><dd><%= bail.irlReference.trimestre %></dd>
  <dt>Valeur</dt><dd><%= bail.irlReference.valeur %></dd>
</dl>

<% if (bail.cautionnement) { %>
  <h2>Cautionnement</h2>
  <dl>
    <dt>Type</dt><dd><%= bail.cautionnement.type %></dd>
    <% if (bail.cautionnement.garant) { %>
      <dt>Garant</dt><dd><%= bail.cautionnement.garant.prenom %> <%= bail.cautionnement.garant.nom %></dd>
      <dt>Email garant</dt><dd><a href="mailto:<%= bail.cautionnement.garant.email %>"><%= bail.cautionnement.garant.email %></a></dd>
      <dt>Téléphone garant</dt><dd><%= bail.cautionnement.garant.telephone || '—' %></dd>
    <% } %>
    <dt>Date de signature</dt><dd><%= formatDate(bail.cautionnement.dateSignature) %></dd>
    <dt>Durée d'engagement</dt><dd><%= bail.cautionnement.dureeEngagement %> mois</dd>
    <% if (bail.cautionnement.montantGaranti) { %>
      <dt>Montant garanti</dt><dd><%= formatMoney(bail.cautionnement.montantGaranti) %></dd>
    <% } %>
  </dl>
<% } else { %>
  <p>Aucun cautionnement pour ce bail.</p>
<% } %>

<p>
  <% if (bail.actifDepuis === null) { %>
    <a href="/baux/<%= bail.id %>/activer" role="button">Activer le bail</a>
    &nbsp;
  <% } %>
  <a href="/baux/<%= bail.id %>/modifier" role="button">Modifier le bail</a>
  &nbsp;
  <% if (bail.actifDepuis !== null) { %>
    <a href="/baux/<%= bail.id %>/echeances">Voir les échéances</a>
    &nbsp;
  <% } %>
  <% if (locals.aDeLActivite || bail.actifDepuis !== null) { %>
    <% if (bail.actifDepuis !== null) { %>
      <button type="button" data-open-dialog="dialog-desactiver-bail">Désactiver</button>
    <% } %>
    <% if (locals.aDeLActivite) { %>
      <p><small>Ce bail a déjà de l'activité (échéances, encaissements ou quittances). Il ne peut plus être supprimé. Vous pouvez en revanche le désactiver.</small></p>
    <% } %>
  <% } else { %>
    <button type="button" class="destructif" data-open-dialog="dialog-supprimer-bail">Supprimer</button>
  <% } %>
</p>

<% if (bail.actifDepuis !== null) { %>
  <%- include('../../partials/confirm-dialog', {
    id: 'dialog-desactiver-bail',
    formAction: '/baux/' + bail.id + '/desactiver',
    message: "Désactiver ce bail ? Les échéances futures ne seront plus émises mais l'historique est préservé.",
    confirmLabel: 'Désactiver le bail',
    cancelLabel: 'Annuler'
  }) %>
<% } %>

<% if (!locals.aDeLActivite && bail.actifDepuis === null) { %>
  <%- include('../../partials/confirm-dialog', {
    id: 'dialog-supprimer-bail',
    formAction: '/baux/' + bail.id + '/supprimer',
    message: 'Supprimer ce bail ? Cette action est irréversible.',
    confirmLabel: 'Supprimer définitivement',
    cancelLabel: 'Annuler'
  }) %>
<% } %>

<h2>État des lieux</h2>
<p>
  <a href="/baux/<%= bail.id %>/edl/entree">EDL d'entrée</a>
  &nbsp;|&nbsp;
  <a href="/baux/<%= bail.id %>/edl/sortie">EDL de sortie</a>
</p>

<section aria-labelledby="indexations-heading">
  <h2 id="indexations-heading">Historique des indexations IRL</h2>
  <% if (!locals.indexations || indexations.length === 0) { %>
    <p>Aucune révision IRL enregistrée pour ce bail.</p>
    <% if (locals.bailIndexable) { %>
      <p><a href="/baux/<%= bail.id %>/indexer" role="button">Lancer la révision</a></p>
    <% } %>
  <% } else { %>
    <table role="table" aria-label="Historique des révisions IRL">
      <caption class="sr-only">Historique des révisions IRL</caption>
      <thead>
        <tr>
          <th scope="col">Date d'effet</th>
          <th scope="col">IRL avant</th>
          <th scope="col">IRL après</th>
          <th scope="col">Loyer avant</th>
          <th scope="col">Loyer après</th>
          <th scope="col">Application</th>
          <th scope="col">Avenant</th>
        </tr>
      </thead>
      <tbody>
        <% indexations.forEach(function(i) { %>
          <tr>
            <td><%= formatDate(i.dateEffet) %></td>
            <td><%= i.irlAvant.trimestre %> — <%= i.irlAvant.valeur %></td>
            <td><%= i.irlApres.trimestre %> — <%= i.irlApres.valeur %></td>
            <td><%= formatMoney(i.loyerAvant) %></td>
            <td><%= formatMoney(i.loyerApres) %></td>
            <td><%= formaterRaisonNonApplication(i.raisonNonApplication) %></td>
            <td>
              <% if (i.indexationAppliquee) { %>
                <a href="/baux/<%= bail.id %>/avenant/<%= i.dateEffet.year %>">Télécharger PDF</a>
              <% } else { %>—<% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<%- include('../../partials/layout-fin') %>
