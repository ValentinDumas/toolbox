<%- include('../../partials/layout-debut', {
  titre: 'Quittance n° ' + quittance.numero,
  breadcrumbs: [
    { url: '/quittances', label: 'Quittances' },
    { label: 'Quittance n° ' + quittance.numero }
  ],
  navActive: 'quittances'
}) %>

<%- include('../../partials/banniere-success', { message: locals.banniereSuccess }) %>
<%- include('../../partials/warning-live', { warning: locals.banniereWarning }) %>

<% if (quittance.annuleeLe) { %>
  <%- include('../../partials/warning-live', {
    warning: 'Quittance annulée le ' + (locals.formatDate ? locals.formatDate(quittance.annuleeLe) : quittance.annuleeLe.toString()) + ' — Raison : ' + quittance.raisonAnnulation + '. Le PDF original reste consultable.'
  }) %>
<% } else if (peutEtreInvalidee) { %>
  <%- include('../../partials/warning-live', {
    warning: "Attention : un encaissement lié à cette quittance a été annulé ou compensé. Cette quittance n'est plus valide. Émettez une nouvelle quittance après régularisation."
  }) %>
<% } %>

<h1<%= quittance.annuleeLe ? ' style="color: var(--pico-muted-color); text-decoration: line-through;"' : '' %>>
  Quittance n° <%= quittance.numero %>
</h1>

<dl>
  <dt>Période</dt>
  <dd>
    <% if (echeance) { %>
      <%= locals.formatDate ? locals.formatDate(echeance.periodeDebut) : echeance.periodeDebut.toString() %>
      → <%= locals.formatDate ? locals.formatDate(echeance.periodeFin) : echeance.periodeFin.toString() %>
    <% } else { %>
      —
    <% } %>
  </dd>

  <dt>Locataire</dt>
  <dd>
    <% if (locataire) { %>
      <%= locataire.prenom %> <%= locataire.nom %>
    <% } else { %>
      —
    <% } %>
  </dd>

  <% if (echeance) { %>
  <dt>Montant encaissé</dt>
  <dd style="font-size: 1.25rem; font-weight: bold;">
    <%= locals.formatMoney ? locals.formatMoney(echeance.total) : echeance.total.enEuros() %>
  </dd>
  <% } %>

  <dt>Date d'émission</dt>
  <dd><%= locals.formatDate ? locals.formatDate(quittance.emiseLe) : quittance.emiseLe.toString() %></dd>

  <dt>Statut</dt>
  <dd>
    <% if (quittance.annuleeLe) { %>
      Annulée
    <% } else { %>
      Active
    <% } %>
  </dd>
</dl>

<a href="/quittances/<%= quittance.id %>/pdf" download>Télécharger la quittance (PDF)</a>

<% if (!quittance.annuleeLe) { %>
  <% if (peutEtreInvalidee) { %>
    <button type="button" data-open-dialog="dialog-annuler-quittance">Marquer comme annulée</button>
  <% } else { %>
    <button type="button" class="destructif" data-open-dialog="dialog-annuler-quittance">
      Annuler la quittance
    </button>
  <% } %>

  <dialog id="dialog-annuler-quittance">
    <article>
      <h2>Annuler cette quittance</h2>
      <p>Le PDF original sera conservé mais la quittance sera marquée comme annulée. Cette action est irréversible (soft-delete).</p>
      <form method="POST" action="/quittances/<%= quittance.id %>/annuler">
        <label for="raison">Raison de l'annulation (obligatoire)
          <textarea id="raison" name="raison" required minlength="3" autofocus rows="3"></textarea>
        </label>
        <footer>
          <div style="display:flex; gap:1rem; justify-content:flex-end;">
            <button type="button" onclick="document.getElementById('dialog-annuler-quittance').close()">
              Fermer
            </button>
            <button type="submit" style="background:#dc2626; color:white; border-color:#dc2626;">
              Confirmer l'annulation
            </button>
          </div>
        </footer>
      </form>
    </article>
  </dialog>

  <script>
  (function() {
    document.querySelectorAll('[data-open-dialog="dialog-annuler-quittance"]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        document.getElementById('dialog-annuler-quittance').showModal();
      });
    });
  })();
  </script>
<% } %>

<%- include('../../partials/layout-fin') %>
