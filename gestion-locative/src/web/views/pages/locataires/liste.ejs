<%- include('../../partials/layout-debut', { titre: 'Locataires', banniereSuccess: locals.banniereSuccess ?? null, navActive: locals.navActive ?? null }) %>

<nav aria-label="Fil d'Ariane">
  <ul>
    <li><a href="/">Accueil</a></li>
    <li>Locataires</li>
  </ul>
</nav>

<h1>Locataires</h1>

<p><a href="/locataires/nouveau" role="button">Créer un locataire</a></p>

<% if (locataires.length === 0) { %>
  <h1>Aucun locataire pour l'instant</h1>
  <p>Créez votre premier locataire pour pouvoir établir un bail.</p>
  <a href="/locataires/nouveau" role="button">Créer un locataire</a>
<% } else { %>
  <%- include('../../partials/data-table', {
    ariaLabel: 'Liste des locataires',
    colonnes: [
      { titre: 'Nom Prénom' },
      { titre: 'Email' },
      { titre: 'Téléphone' },
      { titre: 'Ville' },
      { titre: 'Actions', srOnly: true }
    ],
    lignes: locataires.map(function(l) {
      return [
        l.nom + ' ' + l.prenom,
        l.email,
        l.telephone || '—',
        l.adresseActuelle.ville
      ];
    }),
    actions: function(ligne, i) {
      const l = locataires[i];
      return '<a href="/locataires/' + l.id + '">Voir</a> '
        + '<a href="/locataires/' + l.id + '/modifier">Modifier</a> '
        + '<button type="button" class="destructif" data-open-dialog="dialog-supprimer-' + l.id + '">Supprimer</button>';
    }
  }) %>

  <% locataires.forEach(function(l) { %>
    <%- include('../../partials/confirm-dialog', {
      id: 'dialog-supprimer-' + l.id,
      formAction: '/locataires/' + l.id + '/supprimer',
      message: 'Supprimer ' + l.prenom + ' ' + l.nom + ' ? Cette action est irréversible.',
      confirmLabel: 'Supprimer définitivement',
      cancelLabel: 'Annuler'
    }) %>
  <% }); %>
<% } %>

<%- include('../../partials/layout-fin') %>
