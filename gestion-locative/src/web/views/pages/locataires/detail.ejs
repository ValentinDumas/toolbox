<%- include('../../partials/layout-debut', {
  titre: locataire.prenom + ' ' + locataire.nom,
  breadcrumbs: [{ url: '/locataires', label: 'Locataires' }, { label: locataire.prenom + ' ' + locataire.nom }],
  navActive: 'locataires'
}) %>

<h1><%= locataire.prenom %> <%= locataire.nom %></h1>

<h2>Identité</h2>
<dl>
  <dt>Nom</dt><dd><%= locataire.nom %></dd>
  <dt>Prénom</dt><dd><%= locataire.prenom %></dd>
  <dt>Date de naissance</dt><dd><%= formatDate(locataire.dateNaissance) %></dd>
  <dt>Commune de naissance</dt><dd><%= locataire.lieuNaissance.commune %></dd>
  <dt>Pays de naissance</dt><dd><%= locataire.lieuNaissance.pays %></dd>
  <dt>Nationalité</dt><dd><%= locataire.nationalite %></dd>
</dl>

<h2>Contact</h2>
<dl>
  <dt>Email</dt><dd><a href="mailto:<%= locataire.email %>"><%= locataire.email %></a></dd>
  <dt>Téléphone</dt><dd><%= locataire.telephone || '—' %></dd>
  <dt>Adresse</dt><dd><%= locataire.adresseActuelle.enLigne() %></dd>
</dl>

<p>
  <a href="/locataires/<%= locataire.id %>/modifier" role="button">Modifier le locataire</a>
  &nbsp;
  <button type="button" class="destructif" data-open-dialog="dialog-supprimer-locataire">Supprimer</button>
</p>

<%- include('../../partials/confirm-dialog', {
  id: 'dialog-supprimer-locataire',
  formAction: '/locataires/' + locataire.id + '/supprimer',
  message: 'Supprimer ' + locataire.prenom + ' ' + locataire.nom + ' ? Cette action est irréversible.',
  confirmLabel: 'Supprimer définitivement',
  cancelLabel: 'Annuler'
}) %>

<h2>Baux associés</h2>
<% if (locals.baux && baux.length > 0) { %>
  <%- include('../../partials/data-table', {
    ariaLabel: 'Baux du locataire',
    colonnes: [
      { titre: 'Adresse' },
      { titre: 'Loyer HC', numerique: true },
      { titre: 'Date début' },
      { titre: 'Durée' },
      { titre: 'Actions', srOnly: true }
    ],
    lignes: baux.map(function(b) {
      return [
        biensMap && biensMap[b.bienId] ? biensMap[b.bienId].adresse.enLigne() : b.bienId,
        formatMoney(b.loyerHc),
        formatDate(b.dateDebut),
        b.dureeMois + ' mois'
      ];
    }),
    actions: function(ligne, i) {
      const b = baux[i];
      return '<a href="/baux/' + b.id + '">Voir</a>';
    }
  }) %>
<% } else { %>
  <p>Aucun bail pour ce locataire.</p>
  <a href="/baux/nouveau?locataireId=<%= locataire.id %>">Créer un bail</a>
<% } %>

<section aria-labelledby="documents-heading">
  <h2 id="documents-heading">Documents</h2>

  <%
    const documentsLocataire = locals.documentsLocataire || { items: [], total: 0 };
    const filtreTypeCourant = locals.filtreTypeCourant;
    // Mapping libellé : 4 types autorisés D-120
    const filtresTypes = [
      [null, 'Tous'],
      ['piece_locataire', 'Pièces locataire'],
      ['releve_bancaire', 'Relevés bancaires'],
      ['attestation', 'Attestations'],
      ['autre', 'Autres']
    ];
  %>

  <p style="display: flex; gap: 12px; flex-wrap: wrap; margin: 0 0 12px;">
    <% filtresTypes.forEach(function(f) {
      const courant = (f[0] === filtreTypeCourant) || (f[0] === null && filtreTypeCourant === undefined);
      const href = f[0] === null
        ? '/locataires/' + locataire.id
        : '/locataires/' + locataire.id + '?type=' + f[0];
    %>
      <a
        href="<%= href %>"
        <%= courant ? 'aria-current="page" style="font-weight: 600;"' : '' %>
      ><%= f[1] %></a>
    <% }); %>
  </p>

  <% if (documentsLocataire.total === 0) { %>
    <%- include('../../partials/empty-state', {
      heading: 'Aucun document rattaché à ce Locataire',
      body: 'Téléversez CNI, fiches de paie ou attestations depuis le coffre.',
      ctaUrl: '/coffre/upload',
      ctaLabel: 'Ajouter un document'
    }) %>
  <% } else { %>
    <table aria-label="Documents du Locataire">
      <thead>
        <tr>
          <th scope="col">Date</th>
          <th scope="col">Type</th>
          <th scope="col">Titre</th>
        </tr>
      </thead>
      <tbody>
        <% documentsLocataire.items.forEach(function(j) { %>
          <tr>
            <td style="font-variant-numeric: tabular-nums;"><%= locals.formatDate ? locals.formatDate(j.dateDocument) : j.dateDocument.toString() %></td>
            <td><%= locals.formaterTypeJustificatif ? locals.formaterTypeJustificatif(j.type) : j.type %></td>
            <td><a href="/justificatifs/<%= j.id %>"><%= j.titre %></a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    <p>
      <a href="/coffre?locataire=<%= locataire.id %>">
        Voir tous les documents de ce Locataire (<%= documentsLocataire.total %>)
      </a>
    </p>
  <% } %>
</section>

<%- include('../../partials/layout-fin') %>
