<%- include('../../../partials/layout-debut', {
  titre: 'Corriger la déclaration ' + declaration.exercice,
  breadcrumbs: breadcrumbs,
  navActive: 'fiscalite'
}) %>

<h1>Créer une déclaration corrigée — Exercice <%= declaration.exercice %></h1>

<aside role="note" style="background: var(--couleur-warning-bg, #fef3c7); padding: 12px; margin-bottom: 16px; border-left: 4px solid var(--couleur-warning, #d97706);">
  <span aria-hidden="true">⚠</span>
  <strong>La déclaration originale reste intacte.</strong>
  Cette correction crée un nouvel enregistrement (D-FIS-G4.4 — append-only strict).
  Toutes les corrections sont conservées à des fins d'audit.
</aside>

<p>
  Déclaration originale : régime <strong><%= declaration.regimeApplique === 'micro_bic' ? 'Micro-BIC' : 'Réel' %></strong>,
  recettes <strong><%= (declaration.recettesTotales.toSqliteInteger() / 100).toLocaleString('fr-FR', { style: 'currency', currency: 'EUR' }) %></strong>,
  clôturée le <strong><%= declaration.clotureLe.toString() %></strong>.
</p>

<form method="POST" action="/fiscalite/declarations/<%= declaration.id %>/corriger">
  <label for="motif">
    Motif de la correction <span aria-hidden="true">*</span>
  </label>
  <textarea
    id="motif"
    name="motif"
    required
    rows="4"
    maxlength="2000"
    aria-describedby="hint-motif"
    placeholder="Décrivez la raison de cette correction..."
  ></textarea>
  <small id="hint-motif">Max 2000 caractères. Requis pour l'audit.</small>

  <fieldset>
    <legend>Corrections (champs optionnels — laissez vide pour conserver la valeur originale)</legend>

    <label for="recettesTotalesEuros">Recettes totales corrigées (€)</label>
    <input
      id="recettesTotalesEuros"
      name="recettesTotalesEuros"
      type="number"
      step="0.01"
      min="0"
      placeholder="<%= (declaration.recettesTotales.toSqliteInteger() / 100).toFixed(2) %>"
    />

    <label for="dotationAmortissementEuros">Dotation amortissement corrigée (€)</label>
    <input
      id="dotationAmortissementEuros"
      name="dotationAmortissementEuros"
      type="number"
      step="0.01"
      min="0"
      placeholder="<%= (declaration.dotationAmortissement.toSqliteInteger() / 100).toFixed(2) %>"
    />
  </fieldset>

  <p>
    <a href="/fiscalite/declarations/<%= declaration.id %>" role="button" class="secondary">Annuler</a>
    <button type="submit" class="accent">Créer la déclaration corrigée</button>
  </p>
</form>

<%- include('../../../partials/layout-fin') %>
