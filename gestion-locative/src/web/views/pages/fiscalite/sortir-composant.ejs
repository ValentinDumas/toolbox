<%- include('../../partials/layout-debut', {
  titre: 'Sortir un composant',
  breadcrumbs: [
    { url: '/biens', label: 'Biens' },
    { url: '/biens/' + bien.id, label: bien.adresse.enLigne() },
    { url: '/biens/' + bien.id + '/fiscalite', label: 'Fiscalité' },
    { url: '/biens/' + bien.id + '/fiscalite/amortissement', label: 'Amortissement' },
    { label: 'Sortir un composant' }
  ],
  navActive: 'fiscalite'
}) %>

<h1>Sortir le composant — <%= composant.type %></h1>
<h2><%= bien.adresse.enLigne() %></h2>

<div role="alert" style="background: #fef3c7; border-left: 4px solid #d97706; padding: 1rem; margin-bottom: 1.5rem; border-radius: 0 6px 6px 0;">
  <strong>Opération permanente</strong>
  <p style="margin: 0.5rem 0 0;">
    Cette opération est permanente. Le composant disparaîtra du tableau d'amortissement
    à partir de l'exercice suivant la date de sortie.
    La VNC (valeur nette comptable) sera conservée dans les déclarations annuelles
    pour le calcul de la plus-value future (<strong>LF 2025 art. 84</strong>, CGI art. 150 VB III).
  </p>
</div>

<% if (erreurs && erreurs._global) { %>
  <div role="alert" style="background: #fee2e2; border-left: 4px solid #dc2626; padding: 1rem; margin-bottom: 1.5rem; border-radius: 0 6px 6px 0;">
    <%= erreurs._global %>
  </div>
<% } %>

<form method="POST" action="/biens/<%= bien.id %>/fiscalite/composants/<%= composant.id %>/sortir"
      style="max-width: 480px;">

  <div style="margin-bottom: 1.25rem;">
    <label for="motif" style="display: block; font-weight: 600; margin-bottom: 0.375rem;">
      Motif de sortie <span aria-hidden="true" style="color: #dc2626;">*</span>
    </label>
    <select id="motif" name="motif" required
            aria-required="true"
            aria-describedby="motif-err"
            style="width: 100%; padding: 0.5rem; border: 1px solid <%= (erreurs && erreurs.motif) ? '#dc2626' : '#d1d5db' %>; border-radius: 6px;">
      <option value="">— Choisir un motif —</option>
      <option value="vente" <%= (valeurs && valeurs.motif === 'vente') ? 'selected' : '' %>>Vente</option>
      <option value="mise_au_rebut" <%= (valeurs && valeurs.motif === 'mise_au_rebut') ? 'selected' : '' %>>Mise au rebut</option>
      <option value="sinistre" <%= (valeurs && valeurs.motif === 'sinistre') ? 'selected' : '' %>>Sinistre</option>
      <option value="autre" <%= (valeurs && valeurs.motif === 'autre') ? 'selected' : '' %>>Autre</option>
    </select>
    <% if (erreurs && erreurs.motif) { %>
      <span id="motif-err" role="alert" style="color: #dc2626; font-size: 0.875rem;"><%= erreurs.motif %></span>
    <% } %>
  </div>

  <div style="margin-bottom: 1.25rem;">
    <label for="dateSortieIso" style="display: block; font-weight: 600; margin-bottom: 0.375rem;">
      Date de sortie <span aria-hidden="true" style="color: #dc2626;">*</span>
    </label>
    <input type="date" id="dateSortieIso" name="dateSortieIso" required
           aria-required="true"
           aria-describedby="date-err"
           value="<%= (valeurs && valeurs.dateSortieIso) ? valeurs.dateSortieIso : '' %>"
           style="width: 100%; padding: 0.5rem; border: 1px solid <%= (erreurs && erreurs.dateSortieIso) ? '#dc2626' : '#d1d5db' %>; border-radius: 6px;" />
    <% if (erreurs && erreurs.dateSortieIso) { %>
      <span id="date-err" role="alert" style="color: #dc2626; font-size: 0.875rem;"><%= erreurs.dateSortieIso %></span>
    <% } %>
  </div>

  <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.5rem;">
    <button type="submit" style="padding: 0.625rem 1.25rem; font-weight: 600;">
      Sortir le composant
    </button>
    <a href="/biens/<%= bien.id %>/fiscalite/amortissement"
       style="display: inline-flex; align-items: center; color: #6b7280; text-decoration: none;">
      Annuler
    </a>
  </div>
</form>

<%- include('../../partials/layout-fin') %>
