<%#
  Vue racine fiscalité — GET /fiscalite
  Ownership : Plan 08 (locked depuis Plan 06 qui avait posé un placeholder inline)

  Locals attendus :
    bailleur           : Bailleur (singleton)
    declarations       : DeclarationAnnuelle[]
    anneeCourante      : number
    verdictLmp         : VerdictLmp | null
    compteurNonQualifies : number
    afficherOnboardingBanner : boolean (bailleur.fiscalitePremierAcces === null)

  Surfaces couvertes (UI-SPEC) :
    S1 — onboarding conditionnel
    S2 — bandeau compteur justificatifs à qualifier
    S7 — bandeau verdict tri-état LMNP/LMP
%>
<%- include('../../partials/layout-debut', {
  titre: 'Fiscalité LMNP',
  breadcrumbs: [
    { label: 'Accueil', url: '/' },
    { label: 'Fiscalité' }
  ],
  navActive: 'fiscalite',
  afficherOnboardingBanner: typeof afficherOnboardingBanner !== 'undefined'
    ? afficherOnboardingBanner
    : (bailleur.fiscalitePremierAcces === null)
}) %>

<% if (compteurNonQualifies > 0) { %>
  <%- include('../../partials/banniere-warning', {
    message: compteurNonQualifies + ' justificatif(s) à qualifier pour ' + anneeCourante,
    lienUrl: '/fiscalite/qualification?annee=' + anneeCourante,
    lienLabel: 'Qualifier maintenant'
  }) %>
<% } %>

<% if (verdictLmp) { %>
  <%- include('../../partials/partial-verdict-fiscal', {
    statut: verdictLmp,
    annee: anneeCourante
  }) %>
<% } %>

<% if (locals.alertesCfe && alertesCfe.length > 0) { %>
  <section aria-label="Échéances CFE">
    <% alertesCfe.forEach(function(alerte) { %>
      <%- include('../../partials/partial-bandeau-cfe-echeance', { alerte: alerte }) %>
    <% }); %>
  </section>
<% } %>

<h1>Fiscalité LMNP — Exercice <%= anneeCourante %></h1>

<section>
  <h2>Actions</h2>
  <p>
    <a class="primary" href="/fiscalite/cloturer/<%= anneeCourante %>/etape/1"
       style="padding: 12px 16px; display: inline-block;">Clôturer l'exercice <%= anneeCourante %></a>
  </p>
  <p>
    <a href="/fiscalite/multi-bien?annee=<%= anneeCourante %>">Vue consolidée multi-bien</a>
  </p>
  <p>
    <a href="/fiscalite/revenus-foyer">Revenus du foyer</a>
  </p>
</section>

<section>
  <h2>Déclarations clôturées</h2>
  <% if (declarations.length === 0) { %>
    <%- include('../../partials/empty-state', {
      heading: 'Aucune déclaration clôturée',
      body: "Activez la fiscalité d'un bien, puis clôturez votre premier exercice à la fin de l'année civile.",
      ctaUrl: '/biens',
      ctaLabel: "Activer la fiscalité d'un bien"
    }) %>
  <% } else { %>
    <ul>
      <% declarations.forEach(function(decl) { %>
        <li>
          <a href="/fiscalite/declarations/<%= decl.id %>">Exercice <%= decl.exercice %></a>
          — <%= decl.statutLmnpLmp === 'lmnp_confirme' ? 'LMNP confirmé'
               : decl.statutLmnpLmp === 'lmp_probable' ? 'LMP probable'
               : 'Indéterminé (revenus foyer manquants)' %>
          — <%= decl.recettesTotales.enEuros() %> recettes
        </li>
      <% }); %>
    </ul>
  <% } %>
</section>

<%#
  UI-SPEC §S11 — Bloc "Brouillons de liasse" (Phase 6 / FIS-05).
  D-L6.2 : couvre régime réel ET micro-BIC (Plan 06-02 a peuplé 2042-C-PRO).
%>
<section aria-label="Brouillons de liasse fiscale">
  <h2>Brouillons de liasse</h2>
  <% if (declarations.length === 0) { %>
    <%- include('../../partials/empty-state', {
      heading: 'Aucune déclaration éligible au brouillon liasse',
      body: 'Aucune déclaration clôturée pour ' + anneeCourante + '. Clôturez d\'abord votre exercice fiscal pour générer le brouillon de la liasse.',
      ctaUrl: '/fiscalite',
      ctaLabel: 'Clôturer un exercice fiscal'
    }) %>
  <% } else { %>
    <ul>
      <% declarations.forEach(function(decl) { %>
        <li>
          <a href="/fiscalite/declarations/<%= decl.id %>/liasse">
            Consulter le brouillon liasse <%= decl.exercice %>
            (<%= decl.regimeApplique === 'micro_bic' ? 'micro-BIC' : 'réel' %>)
          </a>
        </li>
      <% }); %>
    </ul>
  <% } %>
</section>

<%- include('../../partials/layout-fin') %>
