<%
/*
 * partial-widget-tf-teom.ejs — Widget décomposition Taxe Foncière / TEOM (D-FIS-G2.9).
 * Variable attendue : item (Justificatif)
 *
 * Pédagogie :
 * - TF nette : déductible (charge_courante_periodique)
 * - TEOM : récupérable sur le locataire → non déductible pour le bailleur
 *   (partie récupérée est neutre fiscalement)
 *
 * Le bouton POST appelle /fiscalite/qualification/decomposer/:id
 * avec les deux lignes (bien courant + bien courant pour les deux parts).
 */
%>
<aside
  aria-label="Décomposition taxe foncière et TEOM"
  style="background: var(--couleur-neutre-bg, #f3f4f6); border-left: 4px solid var(--couleur-neutre, #9ca3af); padding: 1rem; border-radius: 0 6px 6px 0; margin: 0.75rem 0;"
>
  <h3 style="font-size: 0.9em; margin: 0 0 0.75rem 0; color: var(--couleur-neutre, #4b5563);">
    Décomposition TF / TEOM
  </h3>
  <p style="font-size: 0.85em; margin-bottom: 0.75rem; color: var(--couleur-neutre, #6b7280);">
    La Taxe d'Enlèvement des Ordures Ménagères (TEOM) est récupérable sur le locataire.
    Séparez le montant pour qualifier correctement chaque part (BOFIP-BIC-CHG-10-10).
  </p>
  <form method="POST" action="/fiscalite/qualification/decomposer/<%= item.id %>" aria-label="Décomposer TF et TEOM">
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.5rem; margin-bottom: 0.75rem; font-size: 0.9em;">
      <div><strong>Part</strong></div>
      <div><strong>Montant TTC (€)</strong></div>
      <div><strong>Qualification suggérée</strong></div>

      <div>TF nette (déductible)</div>
      <div>
        <input
          type="number"
          name="enfants[0].montantTtcEuros"
          min="0.01"
          step="0.01"
          placeholder="ex : 800"
          required
          style="width: 100%;"
          aria-label="Montant TF nette en euros"
        />
        <input type="hidden" name="enfants[0].bienId" value="<%= item.bienId %>" />
        <input type="hidden" name="enfants[0].titre" value="TF nette — <%= item.titre %>" />
      </div>
      <div style="color: var(--couleur-success, #065f46); font-size: 0.85em;">Charge courante</div>

      <div>TEOM (récupérable locataire)</div>
      <div>
        <input
          type="number"
          name="enfants[1].montantTtcEuros"
          min="0.01"
          step="0.01"
          placeholder="ex : 200"
          required
          style="width: 100%;"
          aria-label="Montant TEOM en euros"
        />
        <input type="hidden" name="enfants[1].bienId" value="<%= item.bienId %>" />
        <input type="hidden" name="enfants[1].titre" value="TEOM récupérable — <%= item.titre %>" />
      </div>
      <div style="color: var(--couleur-neutre, #4b5563); font-size: 0.85em;">Non déductible</div>
    </div>
    <p style="font-size: 0.8em; color: var(--couleur-neutre, #6b7280); margin-bottom: 0.5rem;">
      La somme des deux montants doit être égale au montant total du justificatif.
    </p>
    <button type="submit" style="font-size: 0.9em;">Confirmer la décomposition TF/TEOM</button>
  </form>
</aside>
