<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= titre %> — Gestion locative</title>
    <link rel="stylesheet" href="/styles/pico.min.css" />
    <link rel="stylesheet" href="/styles/app.css" />
    <link rel="stylesheet" href="/styles/print.css" media="print" />
  </head>
  <body>
    <header>
      <nav>
        <ul>
          <li><strong>Gestion locative</strong></li>
        </ul>
        <%- include('sidebar-nav') %>
      </nav>
    </header>

    <% if (typeof afficherOnboardingBanner !== 'undefined' && afficherOnboardingBanner) { %>
      <%- include('partial-onboarding-banner') %>
    <% } %>

    <main class="container">
      <% if (locals.breadcrumbs) { %>
        <%- include('breadcrumbs') %>
      <% } %>
      <%- include('banniere-success', { message: locals.banniereSuccess ?? null }) %>
