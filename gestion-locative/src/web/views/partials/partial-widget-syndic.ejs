<%
/*
 * partial-widget-syndic.ejs — Widget décomposition charges syndic (D-FIS-G2.15).
 * Variable attendue : item (Justificatif)
 *
 * Pédagogie :
 * - Charges courantes : entretien parties communes → charge_courante_periodique
 * - Provisions travaux : quote-part travaux votés → amelioration
 * - Récupérables locataire : charges refacturables → non déductibles (neutre)
 * - Non récupérables : frais de gestion syndic → charge_courante_periodique
 *
 * Invariant Σ = total affiché dynamiquement (JS natif minimal).
 */
%>
<aside
  aria-label="Décomposition charges syndic"
  style="background: var(--couleur-neutre-bg, #f3f4f6); border-left: 4px solid var(--couleur-neutre, #9ca3af); padding: 1rem; border-radius: 0 6px 6px 0; margin: 0.75rem 0;"
>
  <h3 style="font-size: 0.9em; margin: 0 0 0.75rem 0; color: var(--couleur-neutre, #4b5563);">
    Décomposition charges syndic
  </h3>
  <p style="font-size: 0.85em; margin-bottom: 0.75rem; color: var(--couleur-neutre, #6b7280);">
    Décomposez la facture syndic en 4 catégories. La somme doit correspondre au total.
    (BOFIP-BIC-CHG-10-10, D-FIS-G2.15)
  </p>

  <form method="POST" action="/fiscalite/qualification/decomposer/<%= item.id %>" aria-label="Décomposer charges syndic">
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.5rem; margin-bottom: 0.75rem; font-size: 0.9em;" role="table" aria-label="Parts syndic">
      <div role="columnheader"><strong>Catégorie</strong></div>
      <div role="columnheader"><strong>Montant TTC (€)</strong></div>
      <div role="columnheader"><strong>Qualification</strong></div>

      <div role="cell">Charges courantes parties communes</div>
      <div role="cell">
        <input
          type="number" name="enfants[0].montantTtcEuros" min="0" step="0.01"
          placeholder="0.00" class="syndic-part" style="width: 100%;"
          aria-label="Charges courantes en euros"
        />
        <input type="hidden" name="enfants[0].bienId" value="<%= item.bienId %>" />
        <input type="hidden" name="enfants[0].titre" value="Charges courantes — <%= item.titre %>" />
      </div>
      <div role="cell" style="color: var(--couleur-success, #065f46); font-size: 0.85em;">Charge courante</div>

      <div role="cell">Provisions travaux votés</div>
      <div role="cell">
        <input
          type="number" name="enfants[1].montantTtcEuros" min="0" step="0.01"
          placeholder="0.00" class="syndic-part" style="width: 100%;"
          aria-label="Provisions travaux en euros"
        />
        <input type="hidden" name="enfants[1].bienId" value="<%= item.bienId %>" />
        <input type="hidden" name="enfants[1].titre" value="Provisions travaux — <%= item.titre %>" />
      </div>
      <div role="cell" style="color: var(--couleur-warning, #d97706); font-size: 0.85em;">Amélioration</div>

      <div role="cell">Récupérables sur le locataire</div>
      <div role="cell">
        <input
          type="number" name="enfants[2].montantTtcEuros" min="0" step="0.01"
          placeholder="0.00" class="syndic-part" style="width: 100%;"
          aria-label="Charges récupérables en euros"
        />
        <input type="hidden" name="enfants[2].bienId" value="<%= item.bienId %>" />
        <input type="hidden" name="enfants[2].titre" value="Récupérables locataire — <%= item.titre %>" />
      </div>
      <div role="cell" style="color: var(--couleur-neutre, #4b5563); font-size: 0.85em;">Non déductible</div>

      <div role="cell">Frais de gestion non récupérables</div>
      <div role="cell">
        <input
          type="number" name="enfants[3].montantTtcEuros" min="0" step="0.01"
          placeholder="0.00" class="syndic-part" style="width: 100%;"
          aria-label="Frais gestion non récupérables en euros"
        />
        <input type="hidden" name="enfants[3].bienId" value="<%= item.bienId %>" />
        <input type="hidden" name="enfants[3].titre" value="Frais gestion — <%= item.titre %>" />
      </div>
      <div role="cell" style="color: var(--couleur-success, #065f46); font-size: 0.85em;">Charge courante</div>
    </div>

    <p style="font-size: 0.85em; margin-bottom: 0.5rem;">
      Total saisi :
      <strong id="syndic-total-<%= item.id %>">0,00 €</strong>
      / Total document :
      <strong><%= item.montantTtc ? (locals.formatMoney ? locals.formatMoney(item.montantTtc) : item.montantTtc.enEuros()) : '?' %></strong>
    </p>

    <script>
    (function() {
      var form = document.currentScript.closest('form');
      var totalEl = document.getElementById('syndic-total-<%= item.id %>');
      if (!form || !totalEl) return;
      form.querySelectorAll('.syndic-part').forEach(function(input) {
        input.addEventListener('input', function() {
          var total = 0;
          form.querySelectorAll('.syndic-part').forEach(function(i) {
            total += parseFloat(i.value) || 0;
          });
          totalEl.textContent = total.toFixed(2).replace('.', ',') + ' €';
        });
      });
    })();
    </script>

    <button type="submit" style="font-size: 0.9em;">Confirmer la décomposition syndic</button>
  </form>
</aside>
