<%
/*
 * sidebar-nav.ejs — Navigation principale (top-level liens).
 *
 * Phase 3 (UI-SPEC §Sidebar, décision D-40 sobriété) : AUCUN nouveau top-level.
 * Diagnostics accessibles depuis la fiche Bien, EDL et révision IRL depuis la fiche Bail.
 * Ne pas ajouter de lien top-level sans révision explicite de la décision D-40.
 *
 * Active state via `locals.navActive` injecté par chaque route — applique
 * aria-current="page" sur le lien correspondant (WCAG 4.1.2).
 */
%>
<nav aria-label="Navigation principale">
  <ul>
    <li>
      <a href="/biens"<% if (locals.navActive === 'biens') { %> aria-current="page"<% } %>>Biens</a>
    </li>
    <li>
      <a href="/locataires"<% if (locals.navActive === 'locataires') { %> aria-current="page"<% } %>>Locataires</a>
    </li>
    <li>
      <a href="/baux"<% if (locals.navActive === 'baux') { %> aria-current="page"<% } %>>Baux</a>
    </li>
    <li>
      <a href="/coffre"<% if (locals.navActive === 'coffre') { %> aria-current="page"<% } %>>Coffre documentaire</a>
    </li>
    <li>
      <details<% if (locals.navActive === 'encaissements' || locals.navActive === 'echeances' || locals.navActive === 'quittances' || locals.navActive === 'impayes' || locals.navActive === 'relances') { %> open<% } %>>
        <summary>Encaissements</summary>
        <ul>
          <li>
            <a href="/echeances"<% if (locals.navActive === 'echeances') { %> aria-current="page"<% } %>>Toutes les échéances</a>
          </li>
          <li>
            <a href="/encaissements"<% if (locals.navActive === 'encaissements') { %> aria-current="page"<% } %>>Encaissements</a>
          </li>
          <li>
            <a href="/quittances"<% if (locals.navActive === 'quittances') { %> aria-current="page"<% } %>>Quittances</a>
          </li>
          <li>
            <a href="/impayes"<% if (locals.navActive === 'impayes') { %> aria-current="page"<% } %>>Impayés</a>
          </li>
          <li>
            <a href="/relances"<% if (locals.navActive === 'relances') { %> aria-current="page"<% } %>>Relances</a>
          </li>
        </ul>
      </details>
    </li>
    <li>
      <a href="/bailleur"<% if (locals.navActive === 'bailleur') { %> aria-current="page"<% } %>>Profil bailleur</a>
    </li>
  </ul>
</nav>
