<h1>État des lieux d&#39;entrée</h1>





<form method="POST" action="/baux/UUID/edl/entree" novalidate>

  <fieldset>
    <legend>Informations générales</legend>

    <div class="field">
      <label for="date_edl">Date de l'EDL <span aria-hidden="true">*</span></label>
      <input type="date" id="date_edl" name="date_edl" required
        value=""
        aria-describedby="date_edl-error">
      
        <span id="date_edl-error" role="alert" class="error-msg" hidden></span>
      
    </div>

    <div class="field">
      <label>
        <input type="checkbox" name="contradictoire" value="on"
          >
        EDL contradictoire (bailleur + locataire présents)
      </label>
    </div>

    <div class="field">
      <label for="date_signature">Date de signature (si contradictoire)</label>
      <input type="date" id="date_signature" name="date_signature"
        value=""
        aria-describedby="date_signature-error">
      
        <span id="date_signature-error" role="alert" class="error-msg" hidden></span>
      
    </div>
  </fieldset>

  <fieldset>
    <legend>Inventaire mobilier (décret 2015-981) — 12 items obligatoires</legend>
    <p><small>Cochez les éléments présents et indiquez leur état.</small></p>

    
      
      <fieldset style="margin-bottom: 1rem; padding: 0.5rem; border: 1px solid #ccc;">
        <legend>Literie avec couette ou couverture</legend>
        <input type="hidden" name="inventaire[0].typeItem" value="literie">
        <label>
          <input type="checkbox" name="inventaire[0].present" value="on"
            >
          Présent
        </label>
        <div class="field">
          <label for="etat-0">État</label>
          <select id="etat-0" name="inventaire[0].etat">
            <option value="">—</option>
            <option value="bon">Bon</option>
            <option value="moyen">Moyen</option>
            <option value="degrade">Dégradé</option>
          </select>
        </div>
        <div class="field">
          <label for="note-0">Note</label>
          <input type="text" id="note-0" name="inventaire[0].note"
            value="" maxlength="500" placeholder="Remarque éventuelle">
        </div>
      </fieldset>
    
      
      <fieldset style="margin-bottom: 1rem; padding: 0.5rem; border: 1px solid #ccc;">
        <legend>Dispositif d&#39;occultation des fenêtres (chambres)</legend>
