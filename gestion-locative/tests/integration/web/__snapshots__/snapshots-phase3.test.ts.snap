<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ajouter un diagnostic — 1 rue Test, 75001 Paris — Gestion locative</title>
    <link rel="stylesheet" href="/styles/pico.min.css" />
    <link rel="stylesheet" href="/styles/app.css" />
    <link rel="stylesheet" href="/styles/print.css" media="print" />
  </head>
  <body>
    <header>
      <nav>
        <ul>
          <li><strong>Gestion locative</strong></li>
        </ul>
        
<nav aria-label="Navigation principale">
  <ul>
    <li>
      <a href="/biens" aria-current="page">Biens</a>
    </li>
    <li>
      <a href="/locataires">Locataires</a>
    </li>
    <li>
      <a href="/baux">Baux</a>
    </li>
    <li>
      <details>
        <summary>Encaissements</summary>
        <ul>
          <li>
            <a href="/echeances">Toutes les échéances</a>
          </li>
          <li>
            <a href="/encaissements">Encaissements</a>
          </li>
          <li>
            <a href="/quittances">Quittances</a>
          </li>
          <li>
            <a href="/impayes">Impayés</a>
          </li>
          <li>
            <a href="/relances">Relances</a>
          </li>
        </ul>
      </details>
    </li>
    <li>
      <a href="/bailleur">Profil bailleur</a>
    </li>
  </ul>
</nav>

      </nav>
    </header>

    <main class="container">
      
        <nav aria-label="Fil d'Ariane">
  <ol>
    
      <li>
        
          <a href="/biens">Biens</a>
        
      </li>
    
      <li>
        
          <a href="/biens/UUID">1 rue Test, 75001 Paris</a>
        
      </li>
    
      <li>
        
          <span aria-current="page">Ajouter un diagnostic</span>
        
      </li>
    
  </ol>
</nav>

      
      



<h1>Ajouter un diagnostic — 1 rue Test, 75001 Paris</h1>



<form method="POST" action="/biens/UUID/diagnostics" novalidate>

  <div class="field">
    <label for="type">Type de diagnostic <span aria-hidden="true">*</span></label>
    <select
      id="type"
      name="type"
      required
      aria-describedby="type-error"
      
    >
      <option value="">— Sélectionner —</option>
      <option value="dpe" >DPE</option>
      <option value="gaz" >Gaz</option>
      <option value="elec" >Électricité</option>
      <option value="erp" >ERP (risques et pollutions)</option>
    </select>
    <span id="type-error" role="alert" class="error-msg" hidden></span>
  </div>

  
<div class="field">
  <label for="date_emission">Date d&#39;émission <span aria-hidden="true">*</span></label>
  <input
    id="date_emission"
    name="date_emission"
    type="date"
    value=""
    required
    aria-describedby="date_emission-error"
    
  />
  
  <span
    id="date_emission-error"
    role="alert"
    class="error-msg"
    hidden
  ></span>
</div>


  <div class="field">
    <label for="classe_dpe">Classe DPE</label>
    <select
      id="classe_dpe"
      name="classe_dpe"
      aria-describedby="classe_dpe-hint classe_dpe-error"
      
    >
      <option value="">— Sélectionner —</option>
      
        <option value="A" >A</option>
      
        <option value="B" >B</option>
      
        <option value="C" >C</option>
      
        <option value="D" >D</option>
      
        <option value="E" >E</option>
      
        <option value="F" >F</option>
      
        <option value="G" >G</option>
      
    </select>
    <small id="classe_dpe-hint">Obligatoire si type = DPE.</small>
    <span id="classe_dpe-error" role="alert" class="error-msg" hidden></span>
  </div>

  <button type="submit">Enregistrer le diagnostic</button>
  &nbsp;
  <a href="/biens/UUID" role="button" class="secondary">Annuler</a>

</form>

    </main>
  </body>
</html>

"
`;

