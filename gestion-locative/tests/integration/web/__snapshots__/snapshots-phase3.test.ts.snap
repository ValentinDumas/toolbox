    <main class="container">
      
        <nav aria-label="Fil d'Ariane">
  <ol>
    
      <li>
        
          <a href="/baux">Baux</a>
        
      </li>
    
      <li>
        
          <a href="/baux/UUID">Bail</a>
        
      </li>
    
      <li>
        
          <span aria-current="page">Révision IRL</span>
        
      </li>
    
  </ol>
</nav>

      
      



<nav aria-label="Étapes de la révision IRL">
  <ol>
    <li>1. Banner</li>
    <li aria-current="step">2. Saisie IRL</li>
    <li>3. Simulation</li>
    <li>4. Confirmation</li>
    <li>5. Résultat</li>
  </ol>
</nav>
<p><small>Étape 2 sur 5</small></p>


<h1>Saisir le nouvel IRL</h1>
<p>Récupérez la valeur IRL sur <a href="https://www.insee.fr/" target="_blank" rel="noopener">insee.fr</a>.</p>



<form method="POST" action="/baux/UUID/indexer/simuler" novalidate>
  <label for="irl_trimestre">Trimestre IRL <span aria-hidden="true">*</span></label>
  <input
    id="irl_trimestre"
    name="irl_trimestre"
    type="text"
    pattern="(\\d{4}-T[1-4]|[1-4]T\\d{4})"
    required
    autofocus
    value=""
    aria-describedby="hint-trimestre"
  />
  <small id="hint-trimestre">Format : 2026-T1 ou 1T2026.</small>
  

  <label for="irl_valeur">Valeur IRL <span aria-hidden="true">*</span></label>
  <input
    id="irl_valeur"
    name="irl_valeur"
    type="number"
    step="0.01"
    min="1"
    required
    value=""
    aria-describedby="hint-valeur"
  />
  <small id="hint-valeur">Valeur publiée par l'INSEE (ex 145.47).</small>
  

  <p>
    <button type="submit">Simuler la révision</button>
    <a href="/baux/UUID" role="button" class="secondary">Annuler</a>
  </p>
</form>

    </main>
  </body>
</html>

"
