# Invoice Manager — Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Ce fichier ne contient que les chemins des dossiers de travail.
# Tous les autres paramètres (identité, fiscal, OCR, enseignes) se configurent
# depuis le dashboard : python dashboard.py → http://localhost:7800 → Paramètres
#
# Ce fichier est OPTIONNEL. Si absent, les chemins par défaut s'appliquent.
# Priorité : arguments CLI > config.toml > valeurs par défaut
# ─────────────────────────────────────────────────────────────────────────────

[paths]

# Dossier de dépôt des fichiers à traiter.
input = "input/"

# Dossier de destination des fichiers traités avec succès.
processed = "processed/"

# Dossier de destination des fichiers non reconnus (révision manuelle requise).
errors = "errors/"

# Chemin de la base SQLite (source de vérité).
db = "data/invoices.db"

# Dossier de sortie pour les exports CSV et XLSX.
output = "output/"

# Dossier pour le fichier de révision batch.
review = "review/"
